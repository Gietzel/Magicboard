<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Main drawing area -->
    <com.example.magicboard.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="100dp"
        android:background="#FFFFFF" />

    <!-- Prediction text -->
    <TextView
        android:id="@+id/predictionText"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="56dp"
        android:gravity="center"
        android:text=""
        android:textSize="44sp"
        android:textStyle="bold" />

    <!-- Bottom toolbar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@drawable/bottom_bar_bg"
        android:layout_margin="8dp">

        <!-- Left buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/clearButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_clear"
                android:contentDescription="@string/clear"
                android:scaleType="centerInside"
                android:tint="#000000" />

            <ImageButton
                android:id="@+id/eraserButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_eraser"
                android:contentDescription="@string/eraser"
                android:scaleType="centerInside"
                android:tint="#000000" />
        </LinearLayout>

        <!-- Scrollable palette -->
        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:id="@+id/colorPaletteContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <!-- Palette icon -->
        <ImageButton
            android:id="@+id/paletteButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_palette"
            android:contentDescription="@string/palette"
            android:scaleType="centerInside"
            android:tint="#000000" />

    </LinearLayout>

    <!-- Trick mode toggle (placed LAST so it stays above DrawingView) -->
    <ImageButton
        android:id="@+id/modeToggle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_menu"
        android:contentDescription="@string/mode_toggle"
        android:tint="#000000"
        android:scaleType="centerInside" />
</FrameLayout>